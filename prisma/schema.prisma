generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Salary {
  id                 String   @id @default(cuid())
  company            String
  role               String
  level              String
  location           String?
  experience_years   Int?
  base_salary        Int
  bonus              Int      @default(0)
  stock              Int      @default(0)
  total_compensation Int
  confidence_score   Float?
  created_at         DateTime @default(now())

  @@index([company])
  @@index([level])
  @@index([role])
  @@index([location])
  @@index([total_compensation])
}
